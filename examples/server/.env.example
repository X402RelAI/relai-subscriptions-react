# Copy to `.env` (gitignored). The merchant key + webhook secret live here, never
# in the browser.

PORT=8787
RELAI_API_URL=https://api.relai.fi

# Merchant service key that OWNS the plans (needed for cancel). Get one from the
# RelAI dashboard / relai-setup skill.
RELAI_SERVICE_KEY=

# The plan's webhookSecret (returned when you create the plan). Needed to verify
# incoming webhooks. Set your plan's webhookUrl to <public-tunnel>/relai-webhook.
RELAI_WEBHOOK_SECRET=
