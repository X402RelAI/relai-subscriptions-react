# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.

# The plan to charge from (the id after ?plan= in your subscribe link).
VITE_RELAI_PLAN_ID=your_plan_id

# RelAI API base (public endpoints only — no key needed in the browser).
VITE_RELAI_API_URL=https://api.relai.fi

# Solana RPC for the connected wallet. MUST match the plan's network.
# devnet → https://api.devnet.solana.com  ·  mainnet → your own RPC.
VITE_SOLANA_RPC=https://api.devnet.solana.com
