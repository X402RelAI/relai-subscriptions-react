# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.

# The functional (Pro) plan — the id after ?plan= in your subscribe link.
VITE_RELAI_PLAN_ID=your_plan_id

# Optional side tiers — set real plan ids to make Basic/Scale functional too.
VITE_RELAI_PLAN_ID_2=
VITE_RELAI_PLAN_ID_3=

VITE_RELAI_API_URL=https://api.relai.fi
# Must match the plan's network (devnet vs mainnet).
VITE_SOLANA_RPC=https://api.devnet.solana.com

# Demo merchant backend (cancel proxy + webhook feed). See server/.
VITE_BACKEND_URL=http://localhost:8787
